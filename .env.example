# ============================================================
#  .env  —  Copy this file, rename it .env, fill in your keys
#  NEVER share or commit this file to GitHub
# ============================================================

# From the Discord Developer Portal (discord.com/developers/applications)
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_id_here
GUILD_ID=your_discord_server_id_here

# From Google Cloud Console (see README for setup steps)
GOOGLE_SHEETS_API_KEY=your_google_api_key_here

# Your Google Sheet ID (from the URL: /spreadsheets/d/THIS_PART/edit)
STATS_SHEET_ID=your_google_sheet_id_here

# Your league's subreddit (without the r/)
REDDIT_SUBREDDIT=your_subreddit_name_here

# Optional: restrict /loadweek to a specific Discord role name
ADMIN_ROLE=Commissioner
